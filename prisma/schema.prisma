generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("NEON_POSTGRES_PRISMA_URL")
  directUrl = env("NEON_POSTGRES_URL_NON_POOLING")
}

enum UserRole {
  ADMIN
  USER
}

enum LeadStatus {
  NEW
  NEEDS_REVIEW
  VERIFIED
  CALLED
  NO_ANSWER
  CALL_BACK
  INTERESTED
  APPOINTMENT
  QUOTE_SENT
  WON
  INVOICED
  LOST
  REJECTED
  HAS_WEBSITE
  PERMANENTLY_CLOSED
  DO_NOT_CONTACT
  FILTERED
}

enum LeadType {
  NO_WEBSITE
  OUTDATED_WEBSITE
  IMPROVABLE_WEBSITE
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

enum BusinessStatus {
  OPERATIONAL
  CLOSED_TEMPORARILY
  CLOSED_PERMANENTLY
  UNKNOWN
  FUTURE_OPENING
}

enum CoverageStatus {
  PENDING
  RUNNING
  COMPLETE
  FAILED
  PAUSED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETE
  FAILED
  CANCELLED
}

enum JobType {
  DISCOVERY
  REVERIFY
  EXPORT
  WEBSITE_ANALYSIS
}

enum LeadSource {
  GOOGLE_PLACES
  OPENSTREETMAP
  OPEN_DATA
  PUBLIC_WEBSITE
  MANUAL
}

enum WebsiteStatus {
  NO_WEBSITE_CONFIRMED
  NO_WEBSITE_LIKELY
  SOCIAL_ONLY
  WEBSITE_FOUND
  WEBSITE_OUTDATED
  WEBSITE_BROKEN
  MANUAL_REVIEW_REQUIRED
  NO_OWN_WEBSITE
  OWN_WEBSITE
  OUTDATED
  IMPROVABLE
  UNKNOWN
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  username     String        @unique
  name         String
  passwordHash String
  role         UserRole      @default(USER)
  isActive     Boolean       @default(true)
  sessions     Session[]
  history      LeadHistory[]
  notes        LeadNote[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Lead {
  id                            String                 @id @default(cuid())
  externalPlaceId               String                 @unique
  companyName                   String
  normalizedCompanyName         String
  contactPersonName             String?
  email                         String?
  phoneNumber                   String
  normalizedPhoneNumber         String                 @unique
  internationalPhoneNumber      String?
  category                      String
  subCategory                   String?
  country                       String
  province                      String?
  municipality                  String?
  city                          String
  postalCode                    String?
  streetAddress                 String
  houseNumber                   String?
  normalizedAddress             String
  latitude                      Decimal                @db.Decimal(10, 7)
  longitude                     Decimal                @db.Decimal(10, 7)
  googleMapsUrl                 String
  website                       String?
  websiteUrl                    String?
  normalizedDomain              String?
  websiteStatus                 WebsiteStatus          @default(UNKNOWN)
  websiteStatusReason           String?
  websiteConfidence             Int                    @default(0)
  websiteSource                 String?
  sourceUrl                     String?
  sourceFetchedAt               DateTime?
  googlePlaceId                 String?                @unique
  googleWebsiteCheckAttemptedAt DateTime?
  googleWebsiteVerifiedAt       DateTime?
  googleWebsitePresent          Boolean?
  employeeCount                 Int?
  leadType                      LeadType               @default(NO_WEBSITE)
  opportunityScore              Int                    @default(0)
  conversionQualityScore        Int?
  isFiltered                    Boolean                @default(false)
  filterReason                  String?
  doNotContact                  Boolean                @default(false)
  lastWebsiteAnalysisAt         DateTime?
  businessStatus                BusinessStatus
  source                        LeadSource             @default(OPENSTREETMAP)
  confidenceScore               Int                    @default(50)
  confidenceLevel               ConfidenceLevel        @default(MEDIUM)
  isActive                      Boolean                @default(true)
  isSuppressed                  Boolean                @default(false)
  firstDiscoveredAt             DateTime               @default(now())
  lastVerifiedAt                DateTime               @default(now())
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  status                        LeadStatus             @default(NEW)
  notes                         String                 @default("")
  lastContactAt                 DateTime?
  nextFollowUpAt                DateTime?
  contactPerson                 String?
  conversationSummary           String?
  rejectionReason               String?
  quoteAmountCents              Int?
  expectedRevenueCents          Int?
  wonRevenueCents               Int?
  history                       LeadHistory[]
  websiteAnalyses               WebsiteAnalysis[]
  leadNotes                     LeadNote[]
  scanJobs                      ScanJob[]
  evidence                      VerificationEvidence[]
  sourceRecords                 SourceRecord[]
  activities                    LeadActivity[]

  @@unique([normalizedCompanyName, normalizedAddress], map: "lead_name_address_unique")
  @@unique([normalizedCompanyName, latitude, longitude], map: "lead_name_coordinates_unique")
  @@index([isActive, country, createdAt])
  @@index([city])
  @@index([postalCode])
  @@index([category])
  @@index([normalizedDomain])
  @@index([email])
  @@index([confidenceScore])
  @@index([websiteStatus, isActive, createdAt])
  @@index([websiteConfidence, websiteStatus])
  @@index([source, sourceFetchedAt])
  @@index([nextFollowUpAt])
  @@index([googleWebsitePresent, googleWebsiteVerifiedAt])
  @@index([googleWebsiteCheckAttemptedAt])
  @@index([status, isFiltered, leadType])
  @@index([opportunityScore])
  @@index([lastVerifiedAt])
}

model GenerationRun {
  id                 String      @id @default(cuid())
  status             JobStatus   @default(PENDING)
  targetCount        Int         @default(50)
  candidatesFound    Int         @default(0)
  candidatesChecked  Int         @default(0)
  withoutWebsite     Int         @default(0)
  duplicates         Int         @default(0)
  rejected           Int         @default(0)
  stored             Int         @default(0)
  manualReview       Int         @default(0)
  websitesChecked    Int         @default(0)
  permanentlyClosed  Int         @default(0)
  temporarilyClosed  Int         @default(0)
  noWebsite          Int         @default(0)
  outdatedWebsite    Int         @default(0)
  improvableWebsite  Int         @default(0)
  sourceFailures     Int         @default(0)
  estimatedCostCents Int         @default(0)
  placesUsed         Json        @default("[]")
  branchesUsed       Json        @default("[]")
  apiErrors          Json        @default("[]")
  exhausted          Boolean     @default(false)
  cancelRequested    Boolean     @default(false)
  currentPhase       String      @default("Wachten")
  currentSource      String?
  currentRegion      String?
  stopReason         String?
  warnings           Json        @default("[]")
  startedAt          DateTime?
  finishedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  logs               SourceLog[]

  @@index([status, createdAt])
}

model WebsiteAnalysis {
  id                     String   @id @default(cuid())
  leadId                 String
  lead                   Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  websiteUrl             String
  opportunityScore       Int
  mobileScore            Int?
  desktopScore           Int?
  conversionQualityScore Int?
  isReachable            Boolean
  isMobileFriendly       Boolean?
  hasContactForm         Boolean?
  hasClearCta            Boolean?
  hasBrokenLinks         Boolean?
  brokenLinkCount        Int      @default(0)
  hasViewportMeta        Boolean?
  hasOutdatedCopyright   Boolean?
  hasPlaceholderContent  Boolean?
  hasHttps               Boolean?
  hasInvalidSsl          Boolean?
  hasBrokenImages        Boolean?
  brokenImageCount       Int      @default(0)
  hasLegacyTechnology    Boolean?
  hasTinyText            Boolean?
  loadTimeMs             Int?
  reasons                Json
  rawSignals             Json?
  createdAt              DateTime @default(now())

  @@index([leadId, createdAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId, createdAt])
}

model Category {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  googleType String?
  isActive   Boolean  @default(true)
  priority   Int      @default(100)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ExcludedCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  reason    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadHistory {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  event     String
  details   Json?
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model CoverageArea {
  id            String         @id @default(cuid())
  country       String
  region        String
  municipality  String?
  city          String
  latitude      Decimal        @db.Decimal(10, 7)
  longitude     Decimal        @db.Decimal(10, 7)
  radius        Int
  category      String
  status        CoverageStatus @default(PENDING)
  priority      Int            @default(100)
  lastScannedAt DateTime?
  nextScanAt    DateTime       @default(now())
  resultsFound  Int            @default(0)
  apiCallsUsed  Int            @default(0)
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  jobs          ScanJob[]

  @@unique([country, city, category, latitude, longitude])
  @@index([status, nextScanAt, priority])
}

model ScanJob {
  id             String        @id @default(cuid())
  type           JobType
  status         JobStatus     @default(PENDING)
  coverageAreaId String?
  coverageArea   CoverageArea? @relation(fields: [coverageAreaId], references: [id], onDelete: SetNull)
  leadId         String?
  lead           Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  attempt        Int           @default(0)
  maxAttempts    Int           @default(5)
  apiCallsUsed   Int           @default(0)
  recordsFound   Int           @default(0)
  recordsStored  Int           @default(0)
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  nextAttemptAt  DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, nextAttemptAt])
  @@index([type, createdAt])
  @@index([leadId, status])
}

model ApiUsage {
  id                 String   @id @default(cuid())
  dateKey            String
  provider           String
  calls              Int      @default(0)
  estimatedCostCents Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([dateKey, provider])
}

model JobLock {
  name      String   @id
  owner     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SearchCombination {
  id              String    @id @default(cuid())
  country         String
  city            String
  category        String
  source          String
  useCount        Int       @default(0)
  candidatesFound Int       @default(0)
  validLeads      Int       @default(0)
  lastUsedAt      DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([country, city, category, source])
  @@index([lastUsedAt, source])
}

model DuplicateFingerprint {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  leadId      String?
  kind        String
  createdAt   DateTime @default(now())

  @@index([leadId])
}

model SuppressedLead {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  reason      String
  createdAt   DateTime @default(now())
}

model LeadExclusion {
  id               String    @id @default(cuid())
  identityKey      String    @unique
  source           String?
  sourceRecordId   String?
  phoneNormalized  String?
  domainNormalized String?
  nameNormalized   String?
  postalCode       String?
  reason           String
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([source, sourceRecordId])
  @@index([phoneNormalized])
  @@index([domainNormalized])
  @@index([expiresAt])
}

model SourceRecord {
  id                String   @id @default(cuid())
  leadId            String?
  lead              Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  source            String
  sourceRecordId    String
  sourceUrl         String?
  fetchedAt         DateTime @default(now())
  rawName           String?
  rawAddress        String?
  rawPhone          String?
  rawWebsite        String?
  rawBusinessStatus String?
  payload           Json?

  @@unique([source, sourceRecordId])
  @@index([leadId, fetchedAt])
  @@index([source, fetchedAt])
}

model VerificationEvidence {
  id               String   @id @default(cuid())
  leadId           String
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  checkType        String
  result           String
  confidence       Int
  evidenceUrl      String?
  shortExplanation String
  checkedAt        DateTime @default(now())

  @@index([leadId, checkedAt])
  @@index([checkType, result])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorId   String?
  type      String
  summary   String
  details   Json?
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([type, createdAt])
}

model SourceLog {
  id        String        @id @default(cuid())
  runId     String
  run       GenerationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  source    String
  level     String
  message   String
  city      String?
  category  String?
  createdAt DateTime      @default(now())

  @@index([runId, createdAt])
  @@index([source, level, createdAt])
}
