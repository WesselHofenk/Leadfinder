# PostgreSQL is verplicht. Gebruik lokaal een aparte gratis Neon development-branch.
NEON_POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@POOLED_HOST/DATABASE?sslmode=require
NEON_POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require
AUTH_SECRET=vervang-door-minimaal-32-willekeurige-tekens
CRON_SECRET=vervang-door-een-ander-geheim-van-minimaal-32-tekens
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
LEAD_GENERATION_TARGET=50
LEAD_CANDIDATE_BUFFER=200
OSM_SOURCE_ENABLED=true
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_API_URLS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
OVERPASS_TIMEOUT_MS=12000
OVERPASS_TOTAL_TIMEOUT_MS=24000
GENERATION_MAX_DURATION_SECONDS=240
GENERATION_MAX_SOURCE_CALLS=40
GENERATION_BATCH_CANDIDATES=30
GENERATION_BATCH_WEBSITE_CHECKS=3
GENERATION_WATCHDOG_SECONDS=60
WEBSITE_CHECK_CONCURRENCY=3
WEBSITE_FETCH_MAX_BYTES=1000000
WEBSITE_CANDIDATE_DNS_CHECK=true
SESSION_TTL_DAYS=14
NEXT_PUBLIC_APP_URL=http://localhost:3001
